{
  "manifest_version": 3,
  "name": "Storefront Unlocker",
  "version": "0.2.4",
  "description": "Displays the URL captured before a server-side 302 redirect at the top of the redirected page.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "tabs",
    "webRequest",
    "webNavigation"
  ],
  "host_permissions": ["https://*.myshopify.com/*"],
  "background": {
    "scripts": ["src/background.js"]
  },
  "action": {
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png"
    },
    "default_title": "Shopify 密码设置",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "redirect-source-banner@example.local"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "main_frame_tracker",
        "enabled": true,
        "path": "rules/main-frame-tracker.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://*.myshopify.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
